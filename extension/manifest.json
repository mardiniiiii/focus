{
  "manifest_version": 3,
  "name": "Page Chat",
  "version": "1.0.0",
  "description": "Chat with any web page using a local AI model",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:11434/*", "https://slack.com/api/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Page Chat"
  }
}