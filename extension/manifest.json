{
  "manifest_version": 3,
  "name": "Page HTML Reader",
  "version": "1.0.0",
  "description": "Reads and displays the HTML source of the current page",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:11434/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Read Page HTML"
  }
}